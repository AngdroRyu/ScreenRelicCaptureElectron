{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": "src",              // ← ensures all src/ files are included properly
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true
  },
"include": ["src/main/**/*.ts", "src/renderer/**/*.ts", "src/preload/**/*.ts"]
}